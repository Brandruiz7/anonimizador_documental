@{
    ViewData["Title"] = "Acceso denegado";
    Layout = "_Layout";
}

<div class="error-page">
    <div class="error-robot-wrapper">
        <svg class="error-robot-svg" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
            <g class="error-robot-body">
                <rect x="60" y="30" width="80" height="65" rx="16" fill="#1e2d6e" stroke="#e05c5c" stroke-width="2" />
                <line x1="100" y1="30" x2="100" y2="14" stroke="#e05c5c" stroke-width="2" />
                <circle cx="100" cy="10" r="5" fill="#e05c5c" />
                <!-- Ojos — ceñudos -->
                <g class="error-eye-l">
                    <rect x="72" y="50" width="22" height="16" rx="6" fill="#e05c5c" opacity="0.9" />
                    <rect x="78" y="54" width="10" height="8" rx="3" fill="#0d1433" />
                </g>
                <g class="error-eye-r">
                    <rect x="106" y="50" width="22" height="16" rx="6" fill="#e05c5c" opacity="0.9" />
                    <rect x="112" y="54" width="10" height="8" rx="3" fill="#0d1433" />
                </g>
                <!-- Cejas fruncidas -->
                <line x1="72" y1="46" x2="94" y2="50" stroke="#e05c5c" stroke-width="2.5" stroke-linecap="round" />
                <line x1="128" y1="46" x2="106" y2="50" stroke="#e05c5c" stroke-width="2.5" stroke-linecap="round" />
                <!-- Boca — seria -->
                <line x1="84" y1="77" x2="116" y2="77" stroke="#e05c5c" stroke-width="2" stroke-linecap="round" />
                <!-- Cuerpo -->
                <rect x="55" y="100" width="90" height="70" rx="14" fill="#1e2d6e" stroke="#e05c5c" stroke-width="2" />
                <rect x="70" y="112" width="60" height="46" rx="8" fill="#0d1433" opacity="0.6" />
                <!-- Pantalla — candado -->
                <text x="100" y="142" text-anchor="middle" font-family="monospace" font-size="18" font-weight="bold" fill="#e05c5c">403</text>
                <!-- Pies -->
                <rect x="68" y="172" width="22" height="20" rx="6" fill="#1e2d6e" stroke="#e05c5c" stroke-width="1.5" />
                <rect x="110" y="172" width="22" height="20" rx="6" fill="#1e2d6e" stroke="#e05c5c" stroke-width="1.5" />
                <!-- Brazos cruzados -->
                <rect class="error-arm-l" x="34" y="102" width="20" height="48" rx="10" fill="#1e2d6e" stroke="#e05c5c" stroke-width="1.5" />
                <rect class="error-arm-r" x="146" y="102" width="20" height="48" rx="10" fill="#1e2d6e" stroke="#e05c5c" stroke-width="1.5" />
            </g>
        </svg>
        <div class="error-robot-glow error-robot-glow--red"></div>
    </div>

    <div class="error-code error-code--red">403</div>
    <h1 class="error-title">Acceso denegado</h1>
    <p class="error-desc">
        No tenés permiso para acceder a esta sección.<br>
        Si creés que es un error, contactá al administrador.
    </p>
    <a href="@Url.Action("Index", "Home")" class="error-btn">
        ← Volver al inicio
    </a>
</div>