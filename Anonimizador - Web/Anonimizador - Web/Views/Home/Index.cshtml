                <line x1="75" y1="122" x2="125" y2="122"
                      stroke="#61c0cd" stroke-width="1.5" opacity="0.5" />
                <line x1="75" y1="134" x2="115" y2="134"
                      stroke="#61c0cd" stroke-width="1.5" opacity="0.3" />
                <line class="robot-scan-spin" x1="75" y1="128"
                      x2="125" y2="128" stroke="#9decd6"
