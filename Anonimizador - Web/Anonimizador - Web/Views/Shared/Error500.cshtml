@{
    ViewData["Title"] = "Error del servidor";
    Layout = "_Layout";
}

<div class="error-page">
    <div class="error-robot-wrapper">
        <svg class="error-robot-svg" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
            <g class="error-robot-body error-robot-shake">
                <rect x="60" y="30" width="80" height="65" rx="16" fill="#1e2d6e" stroke="#f0a500" stroke-width="2" />
                <line x1="100" y1="30" x2="100" y2="14" stroke="#f0a500" stroke-width="2" />
                <circle cx="100" cy="10" r="5" fill="#f0a500" />
                <!-- Ojos — parpadeando rápido (nervioso) -->
                <g class="error-eye-l error-eye-blink-fast">
                    <rect x="72" y="48" width="22" height="18" rx="6" fill="#f0a500" opacity="0.9" />
                    <rect x="78" y="53" width="10" height="8" rx="3" fill="#0d1433" />
                </g>
                <g class="error-eye-r error-eye-blink-fast">
                    <rect x="106" y="48" width="22" height="18" rx="6" fill="#f0a500" opacity="0.9" />
                    <rect x="112" y="53" width="10" height="8" rx="3" fill="#0d1433" />
                </g>
                <!-- Boca — temblorosa -->
                <path d="M84 76 Q92 80 100 76 Q108 72 116 76" stroke="#f0a500" stroke-width="2" fill="none" stroke-linecap="round" />
                <!-- Humo de la cabeza -->
                <circle cx="130" cy="24" r="5" fill="#f0a500" opacity="0.3" class="error-smoke-1" />
                <circle cx="140" cy="14" r="4" fill="#f0a500" opacity="0.2" class="error-smoke-2" />
                <circle cx="148" cy="6" r="3" fill="#f0a500" opacity="0.1" class="error-smoke-3" />
                <!-- Cuerpo -->
                <rect x="55" y="100" width="90" height="70" rx="14" fill="#1e2d6e" stroke="#f0a500" stroke-width="2" />
                <rect x="70" y="112" width="60" height="46" rx="8" fill="#0d1433" opacity="0.6" />
                <!-- Pantalla — error -->
                <text x="100" y="142" text-anchor="middle" font-family="monospace" font-size="18" font-weight="bold" fill="#f0a500">500</text>
                <!-- Pies -->
                <rect x="68" y="172" width="22" height="20" rx="6" fill="#1e2d6e" stroke="#f0a500" stroke-width="1.5" />
                <rect x="110" y="172" width="22" height="20" rx="6" fill="#1e2d6e" stroke="#f0a500" stroke-width="1.5" />
                <!-- Brazos -->
                <rect class="error-arm-l" x="34" y="102" width="20" height="48" rx="10" fill="#1e2d6e" stroke="#f0a500" stroke-width="1.5" />
                <rect class="error-arm-r" x="146" y="102" width="20" height="48" rx="10" fill="#1e2d6e" stroke="#f0a500" stroke-width="1.5" />
            </g>
        </svg>
        <div class="error-robot-glow error-robot-glow--yellow"></div>
    </div>

    <div class="error-code error-code--yellow">500</div>
    <h1 class="error-title">Algo salió mal</h1>
    <p class="error-desc">
        Esto no debería estar sucediendo... 😅<br>
        Ocurrió un error interno. Ya estamos al tanto.
    </p>
    <a href="@Url.Action("Index", "Home")" class="error-btn">
        ← Volver al inicio
    </a>
</div>