@{
    ViewData["Title"] = "Anonimizar Documento";
}

<div class="light-page">

    <h1 class="page-title">Anonimización de Documentos</h1>

    <!-- INDICADOR DE PASOS -->
    <div class="wizard-steps">
        <div class="wizard-step active" id="step-indicator-1">
            <div class="wizard-step-circle">1</div>
            <span class="wizard-step-label">Documento</span>
        </div>
        <div class="wizard-connector" id="connector-1"></div>
        <div class="wizard-step" id="step-indicator-2">
            <div class="wizard-step-circle">2</div>
            <span class="wizard-step-label">Datos</span>
        </div>
        <div class="wizard-connector" id="connector-2"></div>
        <div class="wizard-step" id="step-indicator-3">
            <div class="wizard-step-circle">3</div>
            <span class="wizard-step-label">Resultado</span>
        </div>
    </div>

    <!-- ETAPA 1: CARGAR DOCUMENTO -->
    <div class="wizard-panel active" id="panel-1">
        <div class="form-card info-card">
            <p class="form-card-title">¿Cómo funciona?</p>
            <p class="info-text">
                Anonimiza documentos Word (<strong>.docx</strong>) y PDF (<strong>.pdf</strong>)
                reemplazando datos sensibles por etiquetas neutrales.
            </p>
            <ul class="info-list">
                <li>📄 Cargue el documento a anonimizar</li>
                <li>🤖 Elija detección automática con IA o ingrese los datos manualmente</li>
                <li>✅ Revise y confirme los datos a anonimizar</li>
                <li>⬇️ Descargue el documento anonimizado</li>
            </ul>
        </div>

        <div class="form-card">
            <p class="form-card-title">Seleccione el documento</p>
            <div class="form-group">
                <label for="File">Archivo (.docx, .pdf)</label>
                <input type="file" id="File" name="documento"
                       accept=".docx,.pdf" required />
            </div>

            <p class="form-card-title" style="margin-top: 24px;">
                ¿Cómo desea identificar los datos sensibles?
            </p>

            <div class="mode-toggle">
                <button type="button" class="mode-btn selected"
                        id="btn-mode-manual" onclick="selectMode('manual')">
                    <span class="mode-btn-icon">✍️</span>
                    <span class="mode-btn-title">Manual</span>
                    <span class="mode-btn-desc">
                        Ingreso los datos que quiero anonimizar
                    </span>
                </button>
                <button type="button" class="mode-btn"
                        id="btn-mode-ai" onclick="selectMode('ai')">
                    <span class="mode-btn-icon">🤖</span>
                    <span class="mode-btn-title">Detección con IA</span>
                    <span class="mode-btn-desc">
                        La IA detecta automáticamente los datos sensibles
                    </span>
                </button>
            </div>
        </div>

        <div class="wizard-nav">
            <div></div>
            <button type="button" class="btn-next" onclick="goToStep2()">
                Siguiente →
            </button>
        </div>
    </div>

    <!-- ETAPA 2A: MANUAL -->
    <div class="wizard-panel" id="panel-2-manual">

        <!-- Datos generales del documento -->
        <div class="form-card">
            <p class="form-card-title">Datos generales del documento</p>
            <div class="form-grid">
                <div class="form-group">
                    <label>Número de expediente</label>
                    <input type="text"
                           id="CaseNumber"
                           name="GeneralData.CaseNumber"
                           placeholder="Ej: 2026-DFO-001" />
                </div>
                <div class="form-group">
                    <label>Número de oficio</label>
                    <input type="text"
                           id="OfficeNumber"
                           name="GeneralData.OfficeNumber"
                           placeholder="Ej: DJ-0933-2026" />
                </div>
            </div>
        </div>

        <!-- Personas -->
        <div class="form-card">
            <p class="form-card-title">Partes a anonimizar</p>
            <div id="personsContainer"></div>
            <div style="margin-top: 16px;">
                <button type="button" id="btnAddPerson" class="btn-secondary">
                    + Anonimizar otra persona
                </button>
            </div>
        </div>

        <div class="wizard-nav">
            <button type="button" class="btn-back" onclick="goToStep1()">
                ← Atrás
            </button>
            <button type="button" class="btn-next" id="btn-process-manual" onclick="processManual()">
                Anonimizar documento
            </button>
        </div>
    </div>

    <!-- ETAPA 2B: IA -->
    <div class="wizard-panel" id="panel-2-ai">
        <div class="form-card">
            <p class="form-card-title">Detección automática con IA</p>

            <!-- Estado: analizando -->
            <div id="ai-analyzing" class="ai-analyzing" style="display:none;">
                <div class="robot-spinner-wrapper" style="margin: 0 auto 16px;">
                    <svg class="robot-spin-svg" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <g class="robot-body-spin">
                            <rect x="60" y="30" width="80" height="65" rx="16" fill="#1e2d6e" stroke="#61c0cd" stroke-width="2" />
                            <line x1="100" y1="30" x2="100" y2="14" stroke="#61c0cd" stroke-width="2" />
                            <circle cx="100" cy="10" r="5" fill="#61c0cd" />
                            <g class="robot-eye-spin-l">
                                <rect x="72" y="48" width="22" height="18" rx="6" fill="#61c0cd" opacity="0.9" />
                                <rect x="78" y="53" width="10" height="8" rx="3" fill="#0d1433" />
                            </g>
                            <g class="robot-eye-spin-r">
                                <rect x="106" y="48" width="22" height="18" rx="6" fill="#61c0cd" opacity="0.9" />
                                <rect x="112" y="53" width="10" height="8" rx="3" fill="#0d1433" />
                            </g>
                            <rect x="80" y="78" width="40" height="8" rx="4" fill="#61c0cd" opacity="0.4" />
                            <rect x="84" y="80" width="8" height="4" rx="2" fill="#61c0cd" />
                            <rect x="96" y="80" width="8" height="4" rx="2" fill="#61c0cd" />
                            <rect x="108" y="80" width="8" height="4" rx="2" fill="#61c0cd" />
                            <rect x="55" y="100" width="90" height="70" rx="14" fill="#1e2d6e" stroke="#61c0cd" stroke-width="2" />
                            <rect x="70" y="112" width="60" height="46" rx="8" fill="#0d1433" opacity="0.6" />
                            <line x1="75" y1="122" x2="125" y2="122" stroke="#61c0cd" stroke-width="1.5" opacity="0.6" />
                            <line x1="75" y1="130" x2="115" y2="130" stroke="#61c0cd" stroke-width="1.5" opacity="0.4" />
                            <line x1="75" y1="138" x2="120" y2="138" stroke="#61c0cd" stroke-width="1.5" opacity="0.5" />
                            <line class="robot-scan-spin" x1="75" y1="130" x2="125" y2="130" stroke="#9decd6" stroke-width="2" opacity="0.8" />
                            <rect x="68" y="172" width="22" height="20" rx="6" fill="#1e2d6e" stroke="#61c0cd" stroke-width="1.5" />
                            <rect x="110" y="172" width="22" height="20" rx="6" fill="#1e2d6e" stroke="#61c0cd" stroke-width="1.5" />
                            <rect class="robot-arm-spin-l" x="34" y="102" width="20" height="48" rx="10" fill="#1e2d6e" stroke="#61c0cd" stroke-width="1.5" />
                            <rect class="robot-arm-spin-r" x="146" y="102" width="20" height="48" rx="10" fill="#1e2d6e" stroke="#61c0cd" stroke-width="1.5" />
                            <g class="robot-lupa-spin">
                                <circle cx="158" cy="82" r="18" stroke="#9decd6" stroke-width="3" fill="rgba(97,192,205,0.1)" />
                                <line x1="171" y1="95" x2="182" y2="106" stroke="#9decd6" stroke-width="3" stroke-linecap="round" />
                                <line x1="150" y1="82" x2="166" y2="82" stroke="#9decd6" stroke-width="1.5" opacity="0.6" />
                                <line x1="158" y1="74" x2="158" y2="90" stroke="#9decd6" stroke-width="1.5" opacity="0.6" />
                            </g>
                        </g>
                    </svg>
                    <div class="robot-spin-glow"></div>
                </div>
                <p class="ai-status-text">Analizando documento...</p>
                <p style="font-size:12px; color:var(--text-muted); margin-top:8px;">
                    Esto puede tomar unos segundos
                </p>
            </div>

            <!-- Resultados detectados -->
            <div id="ai-results" style="display:none;">
                <p style="font-size:13px; color:var(--text-muted); margin-bottom:12px;">
                    La IA detectó los siguientes datos sensibles:
                </p>
                <div class="detected-list" id="detectedList"></div>

                <!-- Vista previa -->
                <p class="form-card-title" style="margin-top:20px;">
                    Vista previa del texto extraído
                </p>
                <div class="preview-box" id="previewBox"></div>

                <!-- Contexto adicional -->
                <p class="form-card-title" style="margin-top:20px;">
                    ¿Algo más que anonimizar?
                </p>
                <textarea class="context-textarea" id="additionalContext"
                          placeholder="Ej: también anonimiza las cuentas bancarias y las fechas del expediente..."></textarea>

                <div style="margin-top:12px; display:flex; gap:10px;">
                    <button type="button" class="btn-secondary"
                            onclick="reAnalyze()">
                        🔄 Reanalizar con contexto
                    </button>
                </div>
            </div>
        </div>

        <div class="wizard-nav">
            <button type="button" class="btn-back" onclick="goToStep1()">
                ← Atrás
            </button>
            <button type="button" class="btn-next"
                    id="btn-process-ai"
                    onclick="processAi()" style="display:none;">
                Anonimizar documento
            </button>
        </div>
    </div>

    <!-- ETAPA 3: RESULTADO -->
    <div class="wizard-panel" id="panel-3">
        <div class="form-card">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
                <p class="form-card-title" style="margin-bottom:0;">
                    Documento anonimizado
                </p>
                <div style="display:flex; gap:10px;">
                    <button type="button"
                            class="btn-back"
                            onclick="goBackFromResult()">
                        ← Corregir
                    </button>
                    <button type="button"
                            class="btn-download"
                            onclick="downloadResult()">
                        ⬇ Descargar
                    </button>
                    <button type="button"
                            class="btn-reset"
                            onclick="resetWizard()">
                        ↺ Procesar otro
                    </button>
                </div>
            </div>

            <!-- Vista previa PDF -->
            <div id="preview-pdf" style="display:none;">
                <iframe id="pdfPreviewFrame"
                        style="width:100%; height:70vh; border:1px solid var(--border-color);
                           border-radius:var(--radius);">
                </iframe>
            </div>

            <!-- Mensaje para DOCX -->
            <div id="preview-docx" style="display:none;">
                <div style="text-align:center; padding:48px 20px;
                    background:var(--bg-main); border-radius:var(--radius);
                    border:1px solid var(--border-color);">
                    <span style="font-size:48px;">📄</span>
                    <p style="font-size:14px; font-weight:600;
                       color:var(--cgr-primary); margin-top:12px;">
                        Vista previa no disponible para Word
                    </p>
                    <p style="font-size:13px; color:var(--text-muted); margin-top:6px;">
                        Descargue el documento para revisarlo en Microsoft Word.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="toastContainer" style="
    position: fixed;
    top: 24px;
    right: 24px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 10px;
    pointer-events: none;
"></div>

@section Scripts {
    <script>
        // =============================================
        // UTILIDAD — ESTADO DE CARGA EN BOTONES
        // =============================================
        function setLoading(btnId, isLoading, loadingText = 'Procesando...') {
            const btn = document.getElementById(btnId);
            if (!btn) return;
            btn.disabled = isLoading;
            btn.dataset.originalText = btn.dataset.originalText || btn.innerHTML;
            btn.innerHTML = isLoading
                ? `<span class="btn-spinner"></span>${loadingText}`
                : btn.dataset.originalText;
        }

        // =============================================
        // ESTADO GLOBAL
        // =============================================
        let currentMode    = 'manual';
        let currentStep    = 1;
        let personCount    = 0;
        let resultBlob     = null;
        let resultFileName = '';
        let aiDetectedData = null;

        // =============================================
        // WIZARD — NAVEGACIÓN
        // =============================================
        function selectMode(mode) {
            currentMode = mode;
            document.getElementById('btn-mode-manual')
                .classList.toggle('selected', mode === 'manual');
            document.getElementById('btn-mode-ai')
                .classList.toggle('selected', mode === 'ai');
        }

        function showPanel(panelId) {
            document.querySelectorAll('.wizard-panel')
                .forEach(p => p.classList.remove('active'));
            document.getElementById(panelId).classList.add('active');
        }

        function updateStepIndicator(step) {
            for (let i = 1; i <= 3; i++) {
                const indicator = document.getElementById(`step-indicator-${i}`);
                indicator.classList.remove('active', 'completed');
                if (i < step)  indicator.classList.add('completed');
                if (i === step) indicator.classList.add('active');
            }
            for (let i = 1; i <= 2; i++) {
                const connector = document.getElementById(`connector-${i}`);
                connector.classList.toggle('completed', i < step);
            }
        }

        function goToStep1() {
            currentStep = 1;
            updateStepIndicator(1);
            showPanel('panel-1');
        }

        async function goToStep2() {
            const fileInput = document.getElementById('File');

            if (!fileInput.files || fileInput.files.length === 0) {
                showAlert('Debe seleccionar un archivo .docx o .pdf.', 'error');
                return;
            }

            const ext = fileInput.files[0].name.split('.').pop().toLowerCase();
            if (!['docx', 'pdf'].includes(ext)) {
                showAlert('Solo se permiten archivos .docx y .pdf.', 'error');
                return;
            }

            currentStep = 2;
            updateStepIndicator(2);

            if (currentMode === 'manual') {
                showPanel('panel-2-manual');
                if (personCount === 0) addPerson();
            } else {
                showPanel('panel-2-ai');
                await startAiAnalysis();
            }
        }

        function goToStep3() {
            currentStep = 3;
            updateStepIndicator(3);
            showPanel('panel-3');

            // Mostrar vista previa según tipo de archivo
            const fileInput = document.getElementById('File');
            const ext = fileInput.files[0]?.name.split('.').pop().toLowerCase();

            if (ext === 'pdf' && resultBlob) {
                // Renderizar PDF en iframe
                const url = window.URL.createObjectURL(resultBlob);
                document.getElementById('pdfPreviewFrame').src = url;
                document.getElementById('preview-pdf').style.display  = 'block';
                document.getElementById('preview-docx').style.display = 'none';
            } else {
                // DOCX — mostrar mensaje
                document.getElementById('preview-pdf').style.display  = 'none';
                document.getElementById('preview-docx').style.display = 'block';
            }
        }

        function goBackFromResult() {
            // Regresar a la etapa 2 según el modo
            currentStep = 2;
            updateStepIndicator(2);

            if (currentMode === 'manual') {
                showPanel('panel-2-manual');
            } else {
                showPanel('panel-2-ai');
            }

            // Limpiar el iframe para liberar memoria
            document.getElementById('pdfPreviewFrame').src = '';
            resultBlob     = null;
            resultFileName = '';
        }

        // =============================================
        // FORMULARIO MANUAL — PERSONAS
        // =============================================
        function createPersonCard(index) {
            return `
            <div class="person-card" id="person-${index}">
                <div class="person-header">
                    <span class="person-title">Persona ${index + 1}</span>
                    ${index > 0
                        ? `<button type="button" class="btn-remove"
                                   onclick="removePerson(${index})">
                               ✕ Eliminar
                           </button>`
                        : ''}
                </div>

                <!-- Datos personales -->
                <p class="person-section-label">Datos personales</p>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Nombre completo</label>
                        <input type="text" name="Persons[${index}].FullName"
                               placeholder="Ej: Juan Pérez Rodríguez" />
                        <div id="variations-${index}-NameVariations"></div>
                        <button type="button"
                                class="btn-add-variation"
                                style="margin-top:6px;"
                                onclick="addFieldVariation(${index}, 'NameVariations',
                                         'Variación nombre',
                                         'Ej: Pérez Rodríguez, Juan Pérez...')">
                            + Variación
                        </button>
                    </div>
                    <div class="form-group">
                        <label>Identificación</label>
                        <input type="text" name="Persons[${index}].Identification"
                               placeholder="Ej: 1-2345-6789" />
                        <div id="variations-${index}-IdVariations"></div>
                        <button type="button"
                                class="btn-add-variation"
                                style="margin-top:6px;"
                                onclick="addFieldVariation(${index}, 'IdVariations',
                                         'Variación cédula',
                                         'Ej: 123456789')">
                            + Variación
                        </button>
                    </div>
                    <div class="form-group">
                        <label>Correo electrónico</label>
                        <input type="email" name="Persons[${index}].Email"
                               placeholder="Ej: juan@correo.com" />
                    </div>
                    <div class="form-group">
                        <label>Teléfono</label>
                        <input type="text" name="Persons[${index}].PhoneNumber"
                               placeholder="Ej: 8888-8888" />
                        <div id="variations-${index}-PhoneVariations"></div>
                        <button type="button"
                                class="btn-add-variation"
                                style="margin-top:6px;"
                                onclick="addFieldVariation(${index}, 'PhoneVariations',
                                         'Variación teléfono',
                                         'Ej: 88888888')">
                            + Variación
                        </button>
                    </div>
                    <div class="form-group">
                        <label>Cargo o puesto</label>
                        <input type="text" name="Persons[${index}].Position"
                               placeholder="Ej: Director Ejecutivo" />
                    </div>
                    <div class="form-group">
                        <label>Dirección</label>
                        <input type="text" name="Persons[${index}].Address"
                               placeholder="Ej: San José, Costa Rica" />
                    </div>
                    <div class="form-group">
                        <label>Institución</label>
                        <input type="text" name="Persons[${index}].Institution"
                               placeholder="Ej: Banco Nacional de Costa Rica" />
                    </div>
                </div>

                <!-- Datos sensibles -->
                <p class="person-section-label" style="margin-top:16px;">
                    Datos sensibles
                </p>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Cuenta bancaria</label>
                        <input type="text" name="Persons[${index}].BankAccount"
                               placeholder="Ej: CR21-0152-0001-0026-3298-66" />
                    </div>
                    <div class="form-group">
                        <label>Condición médica</label>
                        <input type="text" name="Persons[${index}].MedicalCondition"
                               placeholder="Ej: Diabetes tipo 2" />
                    </div>
                </div>

                <!-- Texto libre -->
                <p class="person-section-label" style="margin-top:16px;">
                    Texto libre
                </p>
                <div class="form-group">
                    <label>Texto exacto a anonimizar</label>
                    <input type="text" name="Persons[${index}].FreeText"
                           placeholder="Ej: expediente 2026-001, Sala IV" />
                </div>
            </div>`;
        }

        function addPerson() {
            const container = document.getElementById('personsContainer');
            container.insertAdjacentHTML('beforeend', createPersonCard(personCount));
            personCount++;
        }

        function removePerson(index) {
            document.getElementById(`person-${index}`)?.remove();
            renumberPersons();
        }

        function renumberPersons() {
            const cards = document.querySelectorAll('.person-card');
            cards.forEach((card, i) => {
                card.id = `person-${i}`;
                card.querySelector('.person-title').textContent = `Persona ${i + 1}`;
                const btn = card.querySelector('.btn-remove');
                if (btn) btn.setAttribute('onclick', `removePerson(${i})`);
                else if (i > 0) {
                    card.querySelector('.person-header').insertAdjacentHTML(
                        'beforeend',
                        `<button type="button" class="btn-remove"
                                 onclick="removePerson(${i})">✕ Eliminar</button>`);
                }
                card.querySelectorAll('input').forEach(input => {
                    input.name = input.name.replace(
                        /Persons\[\d+\]/, `Persons[${i}]`);
                });
            });
            personCount = cards.length;
        }

        document.getElementById('btnAddPerson')
            .addEventListener('click', addPerson);

        // =============================================
        // FORMULARIO MANUAL — VALIDACIÓN
        // =============================================
        function hasAtLeastOneField(card) {
            return Array.from(card.querySelectorAll('input'))
                .some(input => input.value.trim() !== '');
        }

        // =============================================
        // MODO MANUAL — PROCESAR
        // =============================================
        async function processManual() {
            const fileInput = document.getElementById('File');
            const cards     = document.querySelectorAll('.person-card');

            if (cards.length === 0) {
                showAlert('Agregue al menos una persona.', 'error');
                return;
            }

            const alguienTieneDatos = Array.from(cards).some(hasAtLeastOneField);
            if (!alguienTieneDatos) {
                showAlert('Completá al menos un campo en una de las personas.', 'error');
                return;
            }

            const formData = new FormData();
            formData.append('documento', fileInput.files[0]);

            const caseNumber   = document.getElementById('CaseNumber')?.value   || '';
            const officeNumber = document.getElementById('OfficeNumber')?.value || '';
            if (caseNumber)   formData.append('GeneralData.CaseNumber',   caseNumber);
            if (officeNumber) formData.append('GeneralData.OfficeNumber', officeNumber);

            cards.forEach(card => {
                card.querySelectorAll('input').forEach(input => {
                    formData.append(input.name, input.value);
                });
            });

            setLoading('btn-process-manual', true, 'Anonimizando...');
            try {
                await submitAndDownload(formData, fileInput.files[0].name);
            } finally {
                setLoading('btn-process-manual', false);
            }
        }

        // =============================================
        // MODO IA — ANÁLISIS
        // =============================================
        async function startAiAnalysis(additionalContext = '') {
            document.getElementById('ai-analyzing').style.display  = 'block';
            document.getElementById('ai-results').style.display    = 'none';
            document.getElementById('btn-process-ai').style.display = 'none';

            try {
                const fileInput = document.getElementById('File');
                const formData  = new FormData();
                formData.append('File', fileInput.files[0]);

                if (additionalContext)
                    formData.append('AdditionalContext', additionalContext);

                const response = await fetch('/ai/analyze', {
                    method: 'POST',
                    body:   formData
                });

                if (!response.ok) {
                    const err = await response.text();
                    showAlert('Error en análisis IA: ' + err, 'error');
                    return;
                }

                aiDetectedData = await response.json();
                renderAiResults(aiDetectedData);

            } catch (err) {
                showAlert('Error de conexión con la IA: ' + err.message, 'error');
            } finally {
                document.getElementById('ai-analyzing').style.display = 'none';
            }
        }

        function renderAiResults(data) {
            const list = document.getElementById('detectedList');
            list.innerHTML = '';

            // Datos generales del documento
            list.insertAdjacentHTML('beforeend', `
                <div class="form-card" style="margin-bottom:16px;
                     border-left: 3px solid var(--primary-mid);">
                    <p class="person-section-label">Datos generales del documento</p>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Número de expediente</label>
                            <input type="text"
                                   id="ai-CaseNumber"
                                   placeholder="Ej: 2026-DFO-001" />
                        </div>
                        <div class="form-group">
                            <label>Número de oficio</label>
                            <input type="text"
                                   id="ai-OfficeNumber"
                                   placeholder="Ej: DJ-0933-2026" />
                        </div>
                    </div>
                </div>`);

            // Si no detectó nada, igual mostramos una persona vacía
            const persons = data.detectedPersons.length > 0
                ? data.detectedPersons
                : [{}];

            persons.forEach((person, i) => {
                // Agregar variaciones al objeto persona antes de construir la card
                list.insertAdjacentHTML('beforeend', buildAiPersonCard(i, person));

                // Agregar variaciones detectadas por IA después de insertar la card
                if (person.nameVariations && person.nameVariations.length > 0) {
                    person.nameVariations.forEach((variation, vi) => {
                        const varId    = `variation-${i}-ai-${vi}`;
                        const fieldsDiv = document.getElementById(`person-fields-${i}`);
                        fieldsDiv.insertAdjacentHTML('beforeend', `
                            <div class="detected-item" id="${varId}">
                                <span class="detected-item-type"
                                      style="color:var(--accent-teal);">
                                    Variación IA
                                </span>
                                <input type="text"
                                       class="detected-item-input variation-input"
                                       data-person="${i}"
                                       data-field="fullName"
                                       data-variation="true"
                                       value="${variation}" />
                                <button type="button"
                                        class="btn-remove-detected"
                                        onclick="removeDetectedItem('${varId}')"
                                        title="Eliminar">✕</button>
                            </div>`);
                    });
                }
            });

            // Datos adicionales detectados por IA
            if (data.additionalData && data.additionalData.length > 0) {
                let extrasHtml = data.additionalData.map((d, idx) => {
                    const itemId = `detected-extra-${idx}`;
                    return `
                        <div class="detected-item" id="${itemId}">
                            <span class="detected-item-type">${d.type}</span>
                            <input type="text"
                                   class="detected-item-input"
                                   data-extra="${idx}"
                                   value="${d.value}" />
                            <button type="button"
                                    class="btn-remove-detected"
                                    onclick="removeDetectedItem('${itemId}')"
                                    title="Eliminar">✕</button>
                        </div>`;
                }).join('');

                list.insertAdjacentHTML('beforeend', `
                    <div class="person-card" style="margin-bottom:16px;
                         border-left: 3px solid var(--accent-orange);">
                        <div class="person-header">
                            <span class="person-title"
                                  style="color:var(--accent-orange);">
                                Datos adicionales
                            </span>
                        </div>
                        <div>${extrasHtml}</div>
                    </div>`);
            }

            // Botón para agregar otra persona en modo IA
            list.insertAdjacentHTML('beforeend', `
                <div style="margin-top:8px; margin-bottom:16px;">
                    <button type="button"
                            class="btn-secondary"
                            onclick="addAiPerson()">
                        + Anonimizar otra persona
                    </button>
                </div>`);

            // Vista previa con resaltado
            const preview   = document.getElementById('previewBox');
            let previewText = data.previewText || '';

            data.detectedPersons.forEach(person => {
                const valuesToHighlight = [
                    person.fullName, person.identification, person.email,
                    person.phoneNumber, person.position, person.address,
                    person.institution, person.bankAccount, person.medicalCondition,
                    ...(person.nameVariations || [])
                ].filter(v => v && typeof v === 'string');

                valuesToHighlight.forEach(val => {
                    const escaped = val.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
                    previewText = previewText.replace(
                        new RegExp(escaped, 'gi'),
                        `<span class="preview-highlight">${val}</span>`);
                });
            });

            preview.innerHTML = previewText;

            document.getElementById('ai-results').style.display     = 'block';
            document.getElementById('btn-process-ai').style.display = 'block';
        }

        // Agregar personas en modo IA
        function addAiPerson() {
            const cards     = document.querySelectorAll(
                '#detectedList .person-card[data-person-index]');
            const newIndex  = cards.length;
            const addButton = document.querySelector('#detectedList .btn-secondary');

            addButton.parentElement.insertAdjacentHTML('beforebegin',
                buildAiPersonCard(newIndex, {}));
        }

        function buildAiPersonCard(i, person) {
            const v = (val) => val || '';
            return `
                <div class="person-card"
                     id="ai-person-${i}"
                     data-person-index="${i}"
                     style="margin-bottom:16px;">
                    <div class="person-header">
                        <span class="person-title">Persona ${i + 1}</span>
                        ${i > 0
                            ? `<button type="button" class="btn-remove"
                                       onclick="removeAiPerson(${i})">
                                   ✕ Eliminar persona
                               </button>`
                            : ''}
                    </div>
                    <p class="person-section-label">Datos personales</p>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Nombre completo</label>
                            <input type="text" class="detected-item-input"
                                   data-person="${i}" data-field="fullName"
                                   value="${v(person.fullName)}"
                                   placeholder="Ej: Juan Pérez Rodríguez" />
                            <div id="variations-${i}-NameVariations"></div>
                            <button type="button"
                                    class="btn-add-variation"
                                    style="margin-top:6px;"
                                    onclick="addFieldVariation(${i}, 'NameVariations',
                                             'Variación nombre',
                                             'Ej: Pérez Rodríguez, Juan Pérez...')">
                                + Variación
                            </button>
                        </div>
                        <div class="form-group">
                            <label>Identificación</label>
                            <input type="text" class="detected-item-input"
                                   data-person="${i}" data-field="identification"
                                   value="${v(person.identification)}"
                                   placeholder="Ej: 1-2345-6789" />
                            <div id="variations-${i}-IdVariations"></div>
                            <button type="button"
                                    class="btn-add-variation"
                                    style="margin-top:6px;"
                                    onclick="addFieldVariation(${i}, 'IdVariations',
                                             'Variación cédula',
                                             'Ej: 123456789')">
                                + Variación
                            </button>
                        </div>
                        <div class="form-group">
                            <label>Correo electrónico</label>
                            <input type="email" class="detected-item-input"
                                   data-person="${i}" data-field="email"
                                   value="${v(person.email)}"
                                   placeholder="Ej: juan@correo.com" />
                        </div>
                        <div class="form-group">
                            <label>Teléfono</label>
                            <input type="text" class="detected-item-input"
                                   data-person="${i}" data-field="phoneNumber"
                                   value="${v(person.phoneNumber)}"
                                   placeholder="Ej: 8888-8888" />
                            <div id="variations-${i}-PhoneVariations"></div>
                            <button type="button"
                                    class="btn-add-variation"
                                    style="margin-top:6px;"
                                    onclick="addFieldVariation(${i}, 'PhoneVariations',
                                             'Variación teléfono',
                                             'Ej: 88888888')">
                                + Variación
                            </button>
                        </div>
                        <div class="form-group">
                            <label>Cargo o puesto</label>
                            <input type="text" class="detected-item-input"
                                   data-person="${i}" data-field="position"
                                   value="${v(person.position)}"
                                   placeholder="Ej: Director Ejecutivo" />
                        </div>
                        <div class="form-group">
                            <label>Dirección</label>
                            <input type="text" class="detected-item-input"
                                   data-person="${i}" data-field="address"
                                   value="${v(person.address)}"
                                   placeholder="Ej: San José, Costa Rica" />
                        </div>
                        <div class="form-group">
                            <label>Institución</label>
                            <input type="text" class="detected-item-input"
                                   data-person="${i}" data-field="institution"
                                   value="${v(person.institution)}"
                                   placeholder="Ej: Banco Nacional de Costa Rica" />
                        </div>
                    </div>
                    <p class="person-section-label" style="margin-top:16px;">
                        Datos sensibles
                    </p>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Cuenta bancaria</label>
                            <input type="text" class="detected-item-input"
                                   data-person="${i}" data-field="bankAccount"
                                   value="${v(person.bankAccount)}"
                                   placeholder="Ej: CR21-0152-0001-0026-3298-66" />
                        </div>
                        <div class="form-group">
                            <label>Condición médica</label>
                            <input type="text" class="detected-item-input"
                                   data-person="${i}" data-field="medicalCondition"
                                   value="${v(person.medicalCondition)}"
                                   placeholder="Ej: Diabetes tipo 2" />
                        </div>
                    </div>
                    <div id="person-fields-${i}" style="margin-top:12px;"></div>
                    <p class="person-section-label" style="margin-top:16px;">
                        Texto libre
                    </p>
                    <div class="form-group">
                        <label>Texto exacto a anonimizar</label>
                        <input type="text" class="detected-item-input"
                               data-person="${i}" data-field="freeText"
                               placeholder="Ej: expediente 2026-001, Sala IV" />
                    </div>
                </div>`;
        }

        // Elimina una persona completa de la lista de IA
        function removeAiPerson(personIndex) {
            // Usar id directo en lugar de nth-child
            const card = document.getElementById(`ai-person-${personIndex}`);
            if (card) card.remove();

            // Eliminar del estado
            if (aiDetectedData?.detectedPersons[personIndex])
                aiDetectedData.detectedPersons.splice(personIndex, 1);

            // Renumerar solo los títulos de personas — no "Datos adicionales"
            document.querySelectorAll('#detectedList .person-card[data-person-index]')
                .forEach((card, i) => {
                    card.querySelector('.person-title').textContent = `Persona ${i + 1}`;
                });
        }

        function removeDetectedItem(itemId, personIndex, fieldKey) {
            // Eliminar visualmente
            document.getElementById(itemId)?.remove();

            // Eliminar del estado
            if (aiDetectedData && personIndex !== undefined && fieldKey !== undefined) {
                const person = aiDetectedData.detectedPersons[personIndex];
                if (person) person[fieldKey] = null;
            }
        }

        async function reAnalyze() {
            const context = document.getElementById('additionalContext').value;
            await startAiAnalysis(context);
        }

        // =============================================
        // MODO IA — PROCESAR
        // =============================================
        async function processAi() {
            const fileInput = document.getElementById('File');
            const formData  = new FormData();
            formData.append('documento', fileInput.files[0]);

            // Datos generales del documento
            const caseNumber   = document.getElementById('ai-CaseNumber')?.value   || '';
            const officeNumber = document.getElementById('ai-OfficeNumber')?.value || '';
            if (caseNumber)   formData.append('GeneralData.CaseNumber',   caseNumber);
            if (officeNumber) formData.append('GeneralData.OfficeNumber', officeNumber);

            // Leer todos los inputs de personas
            const inputs    = document.querySelectorAll('.detected-item-input');
            const personMap = {};

            inputs.forEach(input => {
                const personIdx   = input.dataset.person;
                const fieldKey    = input.dataset.field;
                const isVariation = input.dataset.variation === 'true';
                const value       = input.value.trim();

                if (personIdx === undefined || !fieldKey || !value) return;

                if (!personMap[personIdx])
                    personMap[personIdx] = {
                        nameVariations:  [],
                        idVariations:    [],
                        phoneVariations: []
                    };

                if (isVariation) {
                    // Distribuir variación al campo correcto según su name/data-field
                    const fieldName = input.name || input.dataset.field || '';
                    if (fieldName.includes('NameVariations'))
                        personMap[personIdx].nameVariations.push(value);
                    else if (fieldName.includes('IdVariations'))
                        personMap[personIdx].idVariations.push(value);
                    else if (fieldName.includes('PhoneVariations'))
                        personMap[personIdx].phoneVariations.push(value);
                } else {
                    personMap[personIdx][fieldKey] = value;
                }
            });

            const personIndexes = Object.keys(personMap);

            if (personIndexes.length === 0 && !caseNumber && !officeNumber) {
                showAlert('No hay datos para anonimizar. Revisá los campos detectados.', 'error');
                return;
            }

            personIndexes.forEach((idx, formIdx) => {
                const p = personMap[idx];

                if (p.fullName)         formData.append(`Persons[${formIdx}].FullName`,         p.fullName);
                if (p.identification)   formData.append(`Persons[${formIdx}].Identification`,   p.identification);
                if (p.email)            formData.append(`Persons[${formIdx}].Email`,            p.email);
                if (p.phoneNumber)      formData.append(`Persons[${formIdx}].PhoneNumber`,      p.phoneNumber);
                if (p.position)         formData.append(`Persons[${formIdx}].Position`,         p.position);
                if (p.address)          formData.append(`Persons[${formIdx}].Address`,          p.address);
                if (p.institution)      formData.append(`Persons[${formIdx}].Institution`,      p.institution);
                if (p.bankAccount)      formData.append(`Persons[${formIdx}].BankAccount`,      p.bankAccount);
                if (p.medicalCondition) formData.append(`Persons[${formIdx}].MedicalCondition`, p.medicalCondition);
                if (p.freeText)         formData.append(`Persons[${formIdx}].FreeText`,         p.freeText);

                p.nameVariations.forEach((v, vi) =>
                    formData.append(`Persons[${formIdx}].NameVariations[${vi}]`, v));
                p.idVariations.forEach((v, vi) =>
                    formData.append(`Persons[${formIdx}].IdVariations[${vi}]`, v));
                p.phoneVariations.forEach((v, vi) =>
                    formData.append(`Persons[${formIdx}].PhoneVariations[${vi}]`, v));
            });

            setLoading('btn-process-ai', true, 'Anonimizando...');
            try {
                await submitAndDownload(formData, fileInput.files[0].name);
            } finally {
                setLoading('btn-process-ai', false);
            }
        }

        // =============================================
        // SUBMIT COMÚN
        // =============================================
        async function submitAndDownload(formData, originalFileName) {
            document.getElementById('loadingOverlay').classList.add('active');

            try {
                const response = await fetch('/upload/process', {
                    method: 'POST',
                    body:   formData
                });

                if (!response.ok) {
                    // Intentar extraer el mensaje de la API
                    let errorMsg = 'Error al procesar el documento.';
                    try {
                        const errorText = await response.text();
                        const errorJson = JSON.parse(errorText);
                        errorMsg = errorJson.message ?? errorMsg;
                    } catch {
                        // si no es JSON, usar texto plano
                    }
                    showAlert(errorMsg, 'error');
                    return;
                }

                resultBlob     = await response.blob();
                resultFileName = 'ANONYMIZED_' + originalFileName;

                goToStep3();

            } catch (err) {
                showAlert('Error de conexión: ' + err.message, 'error');
            } finally {
                document.getElementById('loadingOverlay').classList.remove('active');
            }
        }

        // =============================================
        // RESULTADO
        // =============================================
        function downloadResult() {
            if (!resultBlob) return;
            const url = window.URL.createObjectURL(resultBlob);
            const a   = document.createElement('a');
            a.href     = url;
            a.download = resultFileName;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            window.URL.revokeObjectURL(url);
        }

        function resetWizard() {
            currentMode    = 'manual';
            currentStep    = 1;
            personCount    = 0;
            resultBlob     = null;
            resultFileName = '';
            aiDetectedData = null;

            document.getElementById('File').value            = '';
            document.getElementById('CaseNumber').value      = '';
            document.getElementById('OfficeNumber').value    = '';
            document.getElementById('personsContainer').innerHTML = '';
            document.getElementById('detectedList').innerHTML     = '';
            document.getElementById('previewBox').innerHTML       = '';
            document.getElementById('additionalContext').value    = '';
            document.getElementById('ai-results').style.display  = 'none';
            document.getElementById('btn-process-ai').style.display = 'none';
            document.getElementById('pdfPreviewFrame').src        = '';
            document.getElementById('preview-pdf').style.display  = 'none';
            document.getElementById('preview-docx').style.display = 'none';

            selectMode('manual');
            goToStep1();
        }

        // =============================================
        // UTILIDADES
        // =============================================
        function showAlert(message, type, duration = 4000) {
            const container = document.getElementById('toastContainer');
            const id        = 'toast-' + Date.now();

            const icons = { error: '✕', success: '✓', warning: '⚠' };
            const icon  = icons[type] || 'ℹ';

            const toast = document.createElement('div');
            toast.id        = id;
            toast.className = `toast toast-${type}`;
            toast.innerHTML = `
                <span class="toast-icon">${icon}</span>
                <span class="toast-message">${message}</span>
                <button class="toast-close" onclick="removeToast('${id}')">✕</button>
            `;

            container.appendChild(toast);

            // Entrada
            requestAnimationFrame(() => toast.classList.add('toast-visible'));

            // Auto-cierre
            setTimeout(() => removeToast(id), duration);
        }

        function removeToast(id) {
            const el = document.getElementById(id);
            if (!el) return;
            el.classList.remove('toast-visible');
            el.classList.add('toast-hiding');
            setTimeout(() => el.remove(), 400);
        }
    </script>
}