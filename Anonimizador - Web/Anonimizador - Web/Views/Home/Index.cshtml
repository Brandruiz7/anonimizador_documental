            </g>
        </svg>
        <div class="robot-float-glow"></div>
    </div>
</div>

@section Scripts {
    <script>
        // ── SCROLL REVEAL ──
        const revealEls = document.querySelectorAll('.reveal');
        const observer  = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.12 });
        revealEls.forEach(el => observer.observe(el));

        // ── COMPARADOR ──
        const wrapper  = document.getElementById('compareWrapper');
        const anon     = document.getElementById('compareAnon');
        const divider  = document.getElementById('compareDivider');
        let isDragging = false;

        function updateSlider(x) {
            const rect = wrapper.getBoundingClientRect();
            let pct    = (x - rect.left) / rect.width;
            pct = Math.max(0.05, Math.min(0.95, pct));
            anon.style.clipPath = `inset(0 ${(1 - pct) * 100}% 0 0)`;
            divider.style.left  = `${pct * 100}%`;
        }

        wrapper?.addEventListener('mousedown',  e => { isDragging = true; updateSlider(e.clientX); });
        document.addEventListener('mousemove',  e => { if (isDragging) updateSlider(e.clientX); });
        document.addEventListener('mouseup',    () => { isDragging = false; });
        wrapper?.addEventListener('touchstart', e => { isDragging = true; updateSlider(e.touches[0].clientX); });
        document.addEventListener('touchmove',  e => { if (isDragging) updateSlider(e.touches[0].clientX); });
        document.addEventListener('touchend',   () => { isDragging = false; });

        // Animación intro del slider
        setTimeout(() => {
            let pct = 0.5, dir = -1;
            const intro = setInterval(() => {
                pct += dir * 0.006;
                if (pct <= 0.2) dir = 1;
                if (pct >= 0.8) { clearInterval(intro); return; }
                anon.style.clipPath = `inset(0 ${(1 - pct) * 100}% 0 0)`;
                divider.style.left  = `${pct * 100}%`;
            }, 16);
        }, 800);

        // ── ROBOT FLOTANTE ──
        const robotFloat    = document.getElementById('robotFloat');
        const heroSection   = document.querySelector('.home-hero');
        const compareSection = document.getElementById('compareWrapper');

        function checkRobotVisibility() {
            if (!heroSection || !compareSection) return;

            const heroBottom    = heroSection.getBoundingClientRect().bottom;
            const compareTop    = compareSection.getBoundingClientRect().top;
            const windowHeight  = window.innerHeight;

            // Aparece cuando el hero sale del viewport
            const shouldShow = heroBottom < 0;

            // Desaparece cuando el comparador entra en viewport
            const shouldHide = compareTop < windowHeight * 0.6;

            if (shouldHide) {
                robotFloat.classList.remove('visible');
                robotFloat.classList.add('hidden');
            } else if (shouldShow) {
                robotFloat.classList.add('visible');
                robotFloat.classList.remove('hidden');
            } else {
                robotFloat.classList.remove('visible');
                robotFloat.classList.remove('hidden');
            }
        }

        window.addEventListener('scroll', checkRobotVisibility, { passive: true });
        checkRobotVisibility();
    </script>
}