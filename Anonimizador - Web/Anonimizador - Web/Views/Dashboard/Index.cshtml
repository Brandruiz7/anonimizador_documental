@model Anonimizador___Web.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";

    var monthLabels = string.Join(",", Model.Metrics.ByMonth
        .Select(m => $"'{m.Month}'"));
    var monthData = string.Join(",", Model.Metrics.ByMonth
        .Select(m => m.Total));

    var statusLabels = string.Join(",", Model.Metrics.ByStatus
        .Select(s => $"'{s.Status}'"));
    var statusData = string.Join(",", Model.Metrics.ByStatus
        .Select(s => s.Total));

    var userLabels = string.Join(",", Model.Metrics.ByUser
        .Select(u => $"'{u.Username}'"));
    var userData = string.Join(",", Model.Metrics.ByUser
        .Select(u => u.Total));
}
<div class="light-page">
    <h1 class="page-title">Dashboard</h1>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-error">@ViewBag.Error</div>
    }

    <!-- TARJETAS DE RESUMEN -->
    <div class="metrics-cards">
        <div class="metric-card">
            <span class="metric-icon">📄</span>
            <div>
                <p class="metric-value">@Model.Metrics.Summary.TotalDocuments</p>
                <p class="metric-label">Total procesados</p>
            </div>
        </div>
        <div class="metric-card">
            <span class="metric-icon">📅</span>
            <div>
                <p class="metric-value">@Model.Metrics.Summary.ThisMonth</p>
                <p class="metric-label">Este mes</p>
            </div>
        </div>
        <div class="metric-card">
            <span class="metric-icon">👤</span>
            <div>
                <p class="metric-value">@Model.Metrics.Summary.ActiveUsers</p>
                <p class="metric-label">Usuarios activos</p>
            </div>
        </div>
    </div>

    <!-- GRÁFICO DE LÍNEA -->
    <div class="form-card chart-card">
        <p class="form-card-title">Documentos anonimizados por mes</p>
        <canvas id="lineChart"></canvas>
    </div>

    <!-- GRÁFICOS DE DONA -->
    <div class="charts-grid">
        <div class="form-card chart-card">
            <p class="form-card-title">Por estado</p>
            <canvas id="statusChart"></canvas>
        </div>
        <div class="form-card chart-card">
            <p class="form-card-title">Por usuario</p>
            <canvas id="userChart"></canvas>
        </div>
    </div>

    <!-- HISTORIAL -->
    <div class="form-card">
        <div class="dashboard-header">
            <p class="form-card-title">Historial de documentos</p>
            <span class="dashboard-count">@Model.Documents.Count registro(s)</span>
        </div>

        @if (Model.Documents.Count == 0)
        {
            <p class="empty-state">No hay documentos procesados aún.</p>
        }
        else
        {
            <div class="table-wrapper">
                <table class="dashboard-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Archivo</th>
                            <th>Tamaño</th>
                            <th>Subido por</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in Model.Documents)
                        {
                            <tr>
                                <td class="td-id">@doc.DocumentId</td>
                                <td class="td-filename">
                                    <span class="file-icon">📄</span>
                                    @doc.OriginalFileName
                                </td>
                                <td class="td-size">@doc.FileSizeKB KB</td>
                                <td>@doc.UploadedBy</td>
                                <td class="td-date">
                                    @doc.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td>
                                    <span class="status-badge status-@doc.Status.ToLower()">
                                        @doc.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <script>
        // Paleta cohesiva con el nuevo diseño
        const cgr = {
            navy:   '#36499b',
            mid:    '#4571bf',
            light:  '#5eacf1',
            teal:   '#61c0cd',
            mint:   '#9decd6',
            lime:   '#c8f06e',
            orange: '#ffa76c',
            green:  '#9fc54d',
            red:    '#e74c3c'
        };

        // Gráfico de línea — por mes
        new Chart(document.getElementById('lineChart'), {
            type: 'line',
            data: {
                labels: [@Html.Raw(monthLabels)],
                datasets: [{
                    label: 'Documentos',
                    data: [@Html.Raw(monthData)],
                    borderColor: cgr.teal,
                    backgroundColor: 'rgba(97,192,205,0.08)',
                    borderWidth: 2.5,
                    pointBackgroundColor: cgr.teal,
                    pointBorderColor: 'white',
                    pointBorderWidth: 2,
                    pointRadius: 5,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#1a2460',
                        titleColor: '#9decd6',
                        bodyColor: 'white',
                        padding: 12,
                        cornerRadius: 8
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1,
                            color: '#7a8099',
                            font: { size: 11 }
                        },
                        grid: { color: 'rgba(0,0,0,0.05)' }
                    },
                    x: {
                        grid: { display: false },
                        ticks: {
                            color: '#7a8099',
                            font: { size: 11 }
                        }
                    }
                }
            }
        });

        // Gráfico de dona — por estado
        new Chart(document.getElementById('statusChart'), {
            type: 'doughnut',
            data: {
                labels: [@Html.Raw(statusLabels)],
                datasets: [{
                    data: [@Html.Raw(statusData)],
                    backgroundColor: [
                        cgr.teal,
                        cgr.orange,
                        cgr.light,
                        cgr.red
                    ],
                    borderWidth: 0,
                    hoverOffset: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            font: { size: 11 },
                            padding: 16,
                            color: '#7a8099',
                            usePointStyle: true,
                            pointStyleWidth: 8
                        }
                    },
                    tooltip: {
                        backgroundColor: '#1a2460',
                        titleColor: '#9decd6',
                        bodyColor: 'white',
                        padding: 12,
                        cornerRadius: 8
                    }
                },
                cutout: '68%'
            }
        });

        // Gráfico de dona — por usuario
        new Chart(document.getElementById('userChart'), {
            type: 'doughnut',
            data: {
                labels: [@Html.Raw(userLabels)],
                datasets: [{
                    data: [@Html.Raw(userData)],
                    backgroundColor: [
                        cgr.navy,
                        cgr.teal,
                        cgr.mid,
                        cgr.mint,
                        cgr.orange
                    ],
                    borderWidth: 0,
                    hoverOffset: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            font: { size: 11 },
                            padding: 16,
                            color: '#7a8099',
                            usePointStyle: true,
                            pointStyleWidth: 8
                        }
                    },
                    tooltip: {
                        backgroundColor: '#1a2460',
                        titleColor: '#9decd6',
                        bodyColor: 'white',
                        padding: 12,
                        cornerRadius: 8
                    }
                },
                cutout: '68%'
            }
        });
    </script>
}