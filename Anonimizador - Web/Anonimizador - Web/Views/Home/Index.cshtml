@{
    ViewData["Title"] = "Inicio";
}

<div class="home-page">

    <!-- HERO -->
    <section class="home-hero">
        <div class="hero-badge">
            <span class="hero-badge-dot"></span>
            Sistema de Anonimización Documental
        </div>

        <h1 class="hero-title">
            <span class="line-muted">Protege</span>
            <span class="line-bright">datos</span>
            <span class="line-accent">sensibles.</span>
        </h1>

        <p class="hero-subtitle">
            Anonimiza documentos jurídicos con precisión institucional.
            IA combinada con Regex para detectar y reemplazar datos
            personales y sensibles según la normativa PRODHAB.
        </p>

        <div class="hero-scroll">
            <div class="hero-scroll-line"></div>
            Scroll
        </div>
    </section>

    <!-- CÓMO FUNCIONA -->
    <section class="home-section">
        <p class="section-eyebrow reveal">El proceso</p>
        <h2 class="section-heading reveal">
            Tres pasos,<br>resultado profesional.
        </h2>
        <p class="section-body reveal">
            Diseñado para funcionar sin fricción dentro del
            flujo de trabajo institucional.
        </p>

        <div class="steps-grid">
            <div class="step-item reveal">
                <div class="step-num">01</div>
                <span class="step-icon">📄</span>
                <h3 class="step-title">Sube el documento</h3>
                <p class="step-desc">
                    Carga tu archivo .docx o .pdf. Soporta documentos
                    de hasta 100 MB con total seguridad en memoria.
                </p>
            </div>
            <div class="step-item reveal">
                <div class="step-num">02</div>
                <span class="step-icon">🤖</span>
                <h3 class="step-title">IA detecta los datos</h3>
                <p class="step-desc">
                    Motor híbrido: Regex preciso + IA semántica
                    detectan nombres, cédulas, correos, teléfonos
                    y datos sensibles PRODHAB.
                </p>
            </div>
            <div class="step-item reveal">
                <div class="step-num">03</div>
                <span class="step-icon">⬇️</span>
                <h3 class="step-title">Descarga anonimizado</h3>
                <p class="step-desc">
                    Recibe el documento con todos los datos sensibles
                    reemplazados por etiquetas neutrales.
                    Auditoría completa incluida.
                </p>
            </div>
        </div>
    </section>

    <!-- COMPARADOR -->
    <section class="home-section" style="padding-top:0;">
        <p class="section-eyebrow reveal">Antes y después</p>
        <h2 class="section-heading reveal">
            Así queda<br>tu documento.
        </h2>
        <p class="section-body reveal">
            Arrastra el divisor para comparar el documento original
            con el resultado anonimizado.
        </p>

        <div class="compare-wrapper reveal" id="compareWrapper">

            <!-- Original — izquierda -->
            <div class="compare-original">
                <div class="compare-doc">
                    <div class="doc-header">Resolución N° DFO-0234-2026</div>
                    <div class="doc-line">
                        Que el señor
                        <span class="doc-redacted">[P1-Nombre]</span>,
                        portador de la cédula
                        <span class="doc-redacted">[P1-Cédula]</span>,
                    </div>
                    <div class="doc-line">
                        con domicilio en
                        <span class="doc-redacted">[P1-Dir]</span>,
                    </div>
                    <div class="doc-line">
                        correo <span class="doc-redacted">[P1-Correo]</span>
                        y teléfono <span class="doc-redacted">[P1-Tel]</span>,
                        en su condición de
                    </div>
                    <div class="doc-line">
                        <span class="doc-redacted">[P1-Cargo]</span>
                        de la empresa Constructora Nacional S.A.,
                    </div>
                    <div class="doc-line">
                        interpuso recurso de apelación ante esta Contraloría.
                    </div>
                </div>
            </div>

            <!-- Anonimizado — se revela con el slider -->
            <div class="compare-anonymized" id="compareAnon">

                <div class="compare-doc">
                    <div class="doc-header">Resolución N° DFO-0234-2026</div>
                    <div class="doc-line">
                        Que el señor
                        <span class="doc-highlight">Juan Pérez Pérez</span>,
                        portador de la cédula
                        <span class="doc-highlight">1-1111-1111</span>,
                    </div>
                    <div class="doc-line">
                        con domicilio en
                        <span class="doc-highlight">Barrio Los Yoses, Avenida 10, San José</span>,
                    </div>
                    <div class="doc-line">
                        correo <span class="doc-highlight">correo@empresa.cr</span>
                        y teléfono <span class="doc-highlight">2222-2222</span>,
                        en su condición de
                    </div>
                    <div class="doc-line">
                        <span class="doc-highlight">Gerente General</span>
                        de la empresa Constructora Nacional S.A.,
                    </div>
                    <div class="doc-line">
                        interpuso recurso de apelación ante esta Contraloría.
                    </div>
                </div>
            </div>

            <div class="compare-divider" id="compareDivider">
                <div class="compare-handle">⇔</div>
            </div>
        </div>

        <div class="compare-labels">
            <span>📄 Documento original</span>
            <span>🔒 Documento anonimizado</span>
        </div>
    </section>

    <!-- CTA FINAL -->
    <section class="home-cta" id="cta-section">
        <p class="section-eyebrow reveal" style="display:inline-block;">
            Listo para empezar
        </p>
        <h2 class="section-heading reveal"
            style="font-size:clamp(32px,5vw,64px); margin-bottom:20px;">
            ¿Anonimizamos<br>
            <span style="color:var(--cgr-teal);">tu documento?</span>
        </h2>
        <p class="section-body reveal" style="margin:0 auto 48px;">
            Accede al wizard y procesa tu documento en segundos.
        </p>
        <a href="@Url.Action("Index", "Anonymize")"
           class="hero-cta reveal">
            Empezar ahora
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor"
                      stroke-width="1.5" stroke-linecap="round"
                      stroke-linejoin="round" />
            </svg>
        </a>
    </section>

</div>

