@{
    ViewData["Title"] = "Página no encontrada";
    Layout = "_Layout";
}

<div class="error-page">
    <div class="error-robot-wrapper">
        <svg class="error-robot-svg" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
            <g class="error-robot-body">
                <rect x="60" y="30" width="80" height="65" rx="16" fill="#1e2d6e" stroke="#61c0cd" stroke-width="2" />
                <line x1="100" y1="30" x2="100" y2="14" stroke="#61c0cd" stroke-width="2" />
                <circle cx="100" cy="10" r="5" fill="#61c0cd" />
                <!-- Ojos — mirando a los lados (confundido) -->
                <g class="error-eye-l">
                    <rect x="72" y="48" width="22" height="18" rx="6" fill="#61c0cd" opacity="0.9" />
                    <rect x="74" y="53" width="10" height="8" rx="3" fill="#0d1433" />
                </g>
                <g class="error-eye-r">
                    <rect x="106" y="48" width="22" height="18" rx="6" fill="#61c0cd" opacity="0.9" />
                    <rect x="116" y="53" width="10" height="8" rx="3" fill="#0d1433" />
                </g>
                <!-- Boca — confundida -->
                <path d="M84 78 Q100 72 116 78" stroke="#61c0cd" stroke-width="2" fill="none" stroke-linecap="round" />
                <!-- Cuerpo -->
                <rect x="55" y="100" width="90" height="70" rx="14" fill="#1e2d6e" stroke="#61c0cd" stroke-width="2" />
                <rect x="70" y="112" width="60" height="46" rx="8" fill="#0d1433" opacity="0.6" />
                <!-- Pantalla — muestra 404 -->
                <text x="100" y="142" text-anchor="middle" font-family="monospace" font-size="18" font-weight="bold" fill="#61c0cd">404</text>
                <!-- Pies -->
                <rect x="68" y="172" width="22" height="20" rx="6" fill="#1e2d6e" stroke="#61c0cd" stroke-width="1.5" />
                <rect x="110" y="172" width="22" height="20" rx="6" fill="#1e2d6e" stroke="#61c0cd" stroke-width="1.5" />
                <!-- Brazos -->
                <rect class="error-arm-l" x="34" y="102" width="20" height="48" rx="10" fill="#1e2d6e" stroke="#61c0cd" stroke-width="1.5" />
                <rect class="error-arm-r" x="146" y="102" width="20" height="48" rx="10" fill="#1e2d6e" stroke="#61c0cd" stroke-width="1.5" />
            </g>
        </svg>
        <div class="error-robot-glow"></div>
    </div>

    <div class="error-code">404</div>
    <h1 class="error-title">Página no encontrada</h1>
    <p class="error-desc">
        Busqué por todos lados y no encontré nada aquí.<br>
        La página que buscás no existe o fue movida.
    </p>
    <div class="error-path">
        <code>@ViewBag.OriginalPath</code>
    </div>
    <a href="@Url.Action("Index", "Home")" class="error-btn">
        ← Volver al inicio
    </a>
</div>