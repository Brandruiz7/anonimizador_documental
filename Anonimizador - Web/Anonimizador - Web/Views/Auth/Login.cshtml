@model Anonimizador___Web.Models.LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null; // Sin sidebar en el login
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CGR — Anonimizador</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background: var(--bg-main);
        }

        .login-card {
            background: var(--bg-card);
            border-radius: var(--radius);
            border: 1px solid var(--border-color);
            box-shadow: var(--shadow);
            padding: 48px 40px;
            width: 100%;
            max-width: 400px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 24px;
        }

        .login-logo {
            width: 120px;
            filter: invert(1) sepia(1) saturate(3) hue-rotate(190deg);
        }

        .login-title {
            color: var(--primary-color);
            font-size: 14px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            text-align: center;
        }

        .login-form {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .login-error {
            background: #fdecea;
            color: #c0392b;
            border: 1px solid #f5c6c2;
            border-radius: var(--radius);
            padding: 10px 14px;
            font-size: 13px;
            width: 100%;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="login-card">

        <img src="~/images/Logotipo-CGR-blanco-transp.png"
             alt="CGR Costa Rica"
             class="login-logo" />

        <p class="login-title">Anonimizador de Documentos</p>

        @if (!ViewData.ModelState.IsValid)
        {
            foreach (var error in ViewData.ModelState.Values
            .SelectMany(v => v.Errors))
            {
                <div class="login-error">@error.ErrorMessage</div>
            }
        }

        <form method="post"
              action="@Url.Action("Login", "Auth")"
              class="login-form">

            @Html.AntiForgeryToken()

            <div class="form-group">
                <label for="Username">Usuario</label>
                <input type="text"
                       id="Username"
                       name="Username"
                       placeholder="Ingrese su usuario"
                       required />
            </div>

            <div class="form-group">
                <label for="Password">Contraseña</label>
                <input type="password"
                       id="Password"
                       name="Password"
                       placeholder="Ingrese su contraseña"
                       required />
            </div>

            <button type="submit" class="btn-primary" style="width:100%; margin-top:8px;">
                Iniciar Sesión
            </button>

        </form>
    </div>
</body>
</html>