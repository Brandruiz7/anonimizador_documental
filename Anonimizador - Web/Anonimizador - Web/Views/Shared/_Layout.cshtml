<!DOCTYPE html>
<html lang="es">
<head>
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — CGR Anonimizador</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <img src="~/images/Logotipo-CGR-blanco-transp.png"
             alt="CGR Costa Rica"
             class="sidebar-logo" />
        <span class="sidebar-subtitle">Anonimizador<br />de Documentos</span>

        <nav class="sidebar-nav">
            <a href="@Url.Action("Index", "Home")"
               class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                Anonimizar
            </a>
            <a href="@Url.Action("Index", "Dashboard")"
               class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                Dashboard
            </a>
        </nav>
        <div class="sidebar-user">
            <div class="sidebar-user-divider">
                <p class="sidebar-user-label">Usuario</p>
                <p class="sidebar-user-name">
                    @User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value
                </p>
                <p class="sidebar-user-role">
                    @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                </p>
            </div>
            <a href="@Url.Action("Logout", "Auth")"
               class="sidebar-logout">
                Cerrar sesión
            </a>
        </div>
    </aside>

    <!-- LOADING OVERLAY -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="robot-spinner-wrapper">
            <svg class="robot-spin-svg" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                <g class="robot-body-spin">
                    <!-- Cabeza -->
                    <rect x="60" y="30" width="80" height="65" rx="16" fill="#1e2d6e" stroke="#61c0cd" stroke-width="2" />
                    <!-- Antena -->
                    <line x1="100" y1="30" x2="100" y2="14" stroke="#61c0cd" stroke-width="2" />
                    <circle cx="100" cy="10" r="5" fill="#61c0cd" />
                    <!-- Ojos -->
                    <g class="robot-eye-spin-l">
                        <rect x="72" y="48" width="22" height="18" rx="6" fill="#61c0cd" opacity="0.9" />
                        <rect x="78" y="53" width="10" height="8" rx="3" fill="#0d1433" />
                    </g>
                    <g class="robot-eye-spin-r">
                        <rect x="106" y="48" width="22" height="18" rx="6" fill="#61c0cd" opacity="0.9" />
                        <rect x="112" y="53" width="10" height="8" rx="3" fill="#0d1433" />
                    </g>
                    <!-- Boca -->
                    <rect x="80" y="78" width="40" height="8" rx="4" fill="#61c0cd" opacity="0.4" />
                    <rect x="84" y="80" width="8" height="4" rx="2" fill="#61c0cd" />
                    <rect x="96" y="80" width="8" height="4" rx="2" fill="#61c0cd" />
                    <rect x="108" y="80" width="8" height="4" rx="2" fill="#61c0cd" />
                    <!-- Cuerpo -->
                    <rect x="55" y="100" width="90" height="70" rx="14" fill="#1e2d6e" stroke="#61c0cd" stroke-width="2" />
                    <!-- Panel -->
                    <rect x="70" y="112" width="60" height="46" rx="8" fill="#0d1433" opacity="0.6" />
                    <line x1="75" y1="122" x2="125" y2="122" stroke="#61c0cd" stroke-width="1.5" opacity="0.6" />
                    <line x1="75" y1="130" x2="115" y2="130" stroke="#61c0cd" stroke-width="1.5" opacity="0.4" />
                    <line x1="75" y1="138" x2="120" y2="138" stroke="#61c0cd" stroke-width="1.5" opacity="0.5" />
                    <line x1="75" y1="146" x2="108" y2="146" stroke="#61c0cd" stroke-width="1.5" opacity="0.3" />
                    <!-- Scan line animada -->
                    <line class="robot-scan-spin" x1="75" y1="130" x2="125" y2="130" stroke="#9decd6" stroke-width="2" opacity="0.8" />
                    <!-- Piernas -->
                    <rect x="68" y="172" width="22" height="20" rx="6" fill="#1e2d6e" stroke="#61c0cd" stroke-width="1.5" />
                    <rect x="110" y="172" width="22" height="20" rx="6" fill="#1e2d6e" stroke="#61c0cd" stroke-width="1.5" />
                    <!-- Brazos -->
                    <rect class="robot-arm-spin-l" x="34" y="102" width="20" height="48" rx="10" fill="#1e2d6e" stroke="#61c0cd" stroke-width="1.5" />
                    <rect class="robot-arm-spin-r" x="146" y="102" width="20" height="48" rx="10" fill="#1e2d6e" stroke="#61c0cd" stroke-width="1.5" />
                    <!-- Lupa -->
                    <g class="robot-lupa-spin">
                        <circle cx="158" cy="82" r="18" stroke="#9decd6" stroke-width="3" fill="rgba(97,192,205,0.1)" />
                        <line x1="171" y1="95" x2="182" y2="106" stroke="#9decd6" stroke-width="3" stroke-linecap="round" />
                        <line x1="150" y1="82" x2="166" y2="82" stroke="#9decd6" stroke-width="1.5" opacity="0.6" />
                        <line x1="158" y1="74" x2="158" y2="90" stroke="#9decd6" stroke-width="1.5" opacity="0.6" />
                    </g>
                </g>
            </svg>
            <div class="robot-spin-glow"></div>
        </div>
        <span class="loading-text">Procesando documento...</span>
    </div>

    <!-- MAIN -->
    <main class="main-content">
        @RenderBody()
    </main>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- AVISO DE EXPIRACIÓN DE SESIÓN -->
    <div id="sessionWarning" style="
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(54,73,155,0.18);
        z-index: 9999;
        align-items: center;
        justify-content: center;">
        <div style="
            background: white;
            border-radius: 8px;
            padding: 32px 40px;
            text-align: center;
            box-shadow: 0 4px 24px rgba(0,0,0,0.12);
            max-width: 380px;">
            <p style="font-size:15px; font-weight:700; color:#36499b; margin-bottom:8px;">
                ¿Desea continuar?
            </p>
            <p style="font-size:13px; color:#7a8099; margin-bottom:24px;">
                Su sesión está a punto de expirar por inactividad.
            </p>
            <button onclick="renewSession()" style="
                background: #61c0cd;
                color: white;
                border: none;
                border-radius: 8px;
                padding: 10px 28px;
                font-size: 13px;
                font-weight: 600;
                cursor: pointer;
                margin-right: 8px;">
                Continuar sesión
            </button>
            <button onclick="window.location='/auth/logout'" style="
                background: transparent;
                color: #7a8099;
                border: 1px solid #dce3f0;
                border-radius: 8px;
                padding: 10px 20px;
                font-size: 13px;
                cursor: pointer;">
                Cerrar sesión
            </button>
        </div>
    </div>

    <script>
        const WARNING_MS = 25 * 60 * 1000; // 25 minutos
        const EXPIRE_MS  = 30 * 60 * 1000; // 30 minutos
        const SESSION_KEY = 'session_start';

        let warningTimer;
        let expireTimer;

        /**
         * Inicia o retoma el timer de sesión.
         * Usa sessionStorage para persistir el tiempo de inicio
         * entre navegaciones sin resetear el countdown.
         */
        function initSessionTimer() {
            const now        = Date.now();
            const sessionStart = parseInt(sessionStorage.getItem(SESSION_KEY) || '0');

            // Si no hay sesión guardada o es inválida, iniciar nueva
            if (!sessionStart || sessionStart > now) {
                sessionStorage.setItem(SESSION_KEY, now.toString());
                scheduleTimers(WARNING_MS, EXPIRE_MS);
                return;
            }

            // Calcular tiempo restante basado en cuándo inició la sesión
            const elapsed    = now - sessionStart;
            const warningLeft = WARNING_MS - elapsed;
            const expireLeft  = EXPIRE_MS  - elapsed;

            // Si ya expiró, cerrar sesión inmediatamente
            if (expireLeft <= 0) {
                window.location = '/auth/logout';
                return;
            }

            // Si ya pasó el tiempo de aviso, mostrar aviso ahora
            if (warningLeft <= 0) {
                document.getElementById('sessionWarning').style.display = 'flex';
                scheduleTimers(0, expireLeft);
                return;
            }

            scheduleTimers(warningLeft, expireLeft);
        }

        /**
         * Programa los timers de aviso y expiración.
         * param {number} warningDelay - Milisegundos para mostrar el aviso
         * param {number} expireDelay  - Milisegundos para cerrar la sesión
         */
        function scheduleTimers(warningDelay, expireDelay) {
            clearTimeout(warningTimer);
            clearTimeout(expireTimer);

            if (warningDelay > 0) {
                warningTimer = setTimeout(() => {
                    document.getElementById('sessionWarning').style.display = 'flex';
                }, warningDelay);
            }

            expireTimer = setTimeout(() => {
                window.location = '/auth/logout';
            }, expireDelay);
        }

        /**
         * Renueva la sesión del usuario haciendo un request al servidor
         * y reiniciando el timer desde cero.
         */
        function renewSession() {
            document.getElementById('sessionWarning').style.display = 'none';

            fetch('/auth/renew', { method: 'POST' })
                .then(() => {
                    sessionStorage.setItem(SESSION_KEY, Date.now().toString());
                    scheduleTimers(WARNING_MS, EXPIRE_MS);
                })
                .catch(() => window.location = '/auth/logout');
        }

        // Limpiar sessionStorage al cerrar sesión explícitamente
        document.querySelector('a[href*="logout"]')
            ?.addEventListener('click', () => {
                sessionStorage.removeItem(SESSION_KEY);
            });

        // Arrancar el timer al cargar la página
        initSessionTimer();
    </script>
</body>
</html>